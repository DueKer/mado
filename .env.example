# ============================================================
# MADO - 环境变量配置
# ============================================================
# 将此文件复制为 .env.local 并填入你的 API Key
# cp .env.example .env.local
#
# 生产环境建议使用 Vercel Environment Variables
# ============================================================

# OpenAI API Key（GPT-4o 等模型）
OPENAI_API_KEY=sk-...

# Anthropic API Key（Claude 模型）
ANTHROPIC_API_KEY=sk-ant-...
